# 开发环境配置示例
# 复制本文件为 application-dev.yml 后填入真实值，application-dev.yml 不提交仓库
# 也可以通过环境变量注入，环境变量名与占位符一致

spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: ${MYSQL_URL:jdbc:mysql://localhost:3306/novablog?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai}
    username: ${MYSQL_USERNAME:root}
    password: ${MYSQL_PASSWORD:}
  data:
    redis:
      host: ${REDIS_HOST:localhost}
      port: ${REDIS_PORT:6379}
      password: ${REDIS_PASSWORD:}
      database: ${REDIS_DATABASE:0}

# JWT 密钥：长度必须 >= 32 位，建议 >= 64 位，包含大小写字母、数字和特殊字符
jwt:
  secret: ${NOVABLOG_JWT_SECRET:}
  expiration: ${NOVABLOG_JWT_EXPIRATION:7200000}
  refresh-expiration: ${NOVABLOG_JWT_REFRESH_EXPIRATION:604800000}

# MyBatis 开发环境输出 SQL 日志
mybatis:
  configuration:
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl

# 日志配置
logging:
  level:
    com.novablog.mapper: debug

# 阿里云 OSS 配置
aliyun:
  oss:
    endpoint: ${ALIYUN_OSS_ENDPOINT:}
    bucket: ${ALIYUN_OSS_BUCKET:}
    access-key-id: ${ALIYUN_OSS_ACCESS_KEY_ID:}
    access-key-secret: ${ALIYUN_OSS_ACCESS_KEY_SECRET:}

# AI / RAG 配置（基于 Spring AI 框架）
# 对话模型和嵌入模型由 AiModelConfig 根据 ai.chat.provider / ai.embedding.provider 动态装配
# 注意：DeepSeek 目前仅支持 /chat/completions，嵌入模型需使用 OpenAI、百炼等兼容提供商
ai:
  enabled: ${AI_ENABLED:true}
  chat:
    provider: ${AI_CHAT_PROVIDER:deepseek}
    deepseek:
      base-url: ${DEEPSEEK_BASE_URL:https://api.deepseek.com}
      api-key: ${DEEPSEEK_API_KEY:}
      model: ${DEEPSEEK_CHAT_MODEL:deepseek-chat}
      temperature: ${DEEPSEEK_CHAT_TEMPERATURE:0.7}
      max-tokens: ${DEEPSEEK_CHAT_MAX_TOKENS:1024}
    openai:
      base-url: ${OPENAI_BASE_URL:https://api.openai.com/v1}
      api-key: ${OPENAI_API_KEY:}
      model: ${OPENAI_CHAT_MODEL:gpt-4o-mini}
      temperature: ${OPENAI_CHAT_TEMPERATURE:0.7}
      max-tokens: ${OPENAI_CHAT_MAX_TOKENS:1024}
    bailian:
      base-url: ${BAILIAN_BASE_URL:https://dashscope.aliyuncs.com/compatible-mode/v1}
      api-key: ${BAILIAN_API_KEY:}
      model: ${BAILIAN_CHAT_MODEL:qwen-plus}
      temperature: ${BAILIAN_CHAT_TEMPERATURE:0.7}
      max-tokens: ${BAILIAN_CHAT_MAX_TOKENS:1024}
  embedding:
    provider: ${AI_EMBEDDING_PROVIDER:openai}
    deepseek:
      base-url: ${DEEPSEEK_BASE_URL:https://api.deepseek.com}
      api-key: ${DEEPSEEK_API_KEY:}
      model: ${DEEPSEEK_EMBEDDING_MODEL:deepseek-embedding}
    openai:
      base-url: ${OPENAI_BASE_URL:https://api.openai.com/v1}
      api-key: ${OPENAI_API_KEY:}
      model: ${OPENAI_EMBEDDING_MODEL:text-embedding-3-small}
    bailian:
      base-url: ${BAILIAN_BASE_URL:https://dashscope.aliyuncs.com/compatible-mode/v1}
      api-key: ${BAILIAN_API_KEY:}
      model: ${BAILIAN_EMBEDDING_MODEL:text-embedding-v3}
  rag:
    top-k: ${RAG_TOP_K:5}
    chunk-size: ${RAG_CHUNK_SIZE:500}
    chunk-overlap: ${RAG_CHUNK_OVERLAP:100}
    max-context-tokens: ${RAG_MAX_CONTEXT_TOKENS:3000}
    rate-limit-per-minute: ${RAG_RATE_LIMIT:10}
