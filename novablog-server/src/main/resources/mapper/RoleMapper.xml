<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novablog.mapper.RoleMapper">

    <resultMap id="roleResultMap" type="com.novablog.entity.Role">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="findRoleNamesByUserId" resultType="java.lang.String">
        SELECT r.name
        FROM user_role ur
        JOIN role r ON r.id = ur.role_id
        WHERE ur.user_id = #{userId}
    </select>

    <select id="findPermissionNamesByUserId" resultType="java.lang.String">
        SELECT DISTINCT p.name
        FROM user_role ur
        JOIN role_permission rp ON rp.role_id = ur.role_id
        JOIN permission p ON p.id = rp.permission_id
        WHERE ur.user_id = #{userId}
    </select>

</mapper>
