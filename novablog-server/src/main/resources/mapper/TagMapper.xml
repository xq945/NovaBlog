<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novablog.mapper.TagMapper">

    <resultMap id="tagResultMap" type="com.novablog.entity.Tag">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
    </resultMap>

    <!-- 查询所有标签 -->
    <select id="findAll" resultMap="tagResultMap">
        SELECT * FROM tag ORDER BY id
    </select>

    <!-- 根据ID查询标签 -->
    <select id="findById" resultMap="tagResultMap">
        SELECT * FROM tag WHERE id = #{id} LIMIT 1
    </select>

    <!-- 根据名称查询标签 -->
    <select id="findByName" resultMap="tagResultMap">
        SELECT * FROM tag WHERE name = #{name} LIMIT 1
    </select>

    <!-- 插入新标签 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tag (name) VALUES (#{name})
    </insert>

    <!-- 根据文章ID查询标签列表 -->
    <select id="findByArticleId" resultMap="tagResultMap">
        SELECT t.* FROM tag t
        INNER JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
        ORDER BY t.id
    </select>

</mapper>
