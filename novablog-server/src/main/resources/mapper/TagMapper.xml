<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novablog.mapper.TagMapper">

    <resultMap id="tagResultMap" type="com.novablog.entity.Tag">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
    </resultMap>

    <!-- 查询所有标签 -->
    <select id="findAll" resultMap="tagResultMap">
        SELECT * FROM tag ORDER BY id
    </select>

    <!-- 根据ID查询标签 -->
    <select id="findById" resultMap="tagResultMap">
        SELECT * FROM tag WHERE id = #{id} LIMIT 1
    </select>

    <!-- 根据名称查询标签 -->
    <select id="findByName" resultMap="tagResultMap">
        SELECT * FROM tag WHERE name = #{name} LIMIT 1
    </select>

    <!-- 根据文章ID查询标签列表 -->
    <select id="findByArticleId" resultMap="tagResultMap">
        SELECT t.* FROM tag t
        INNER JOIN article_tag at ON t.id = at.tag_id
        WHERE at.article_id = #{articleId}
        ORDER BY t.id
    </select>

    <!-- 更新标签 -->
    <update id="update">
        UPDATE tag SET name = #{name} WHERE id = #{id}
    </update>

    <!-- 删除文章标签关联 -->
    <delete id="deleteArticleTagByTagId">
        DELETE FROM article_tag WHERE tag_id = #{tagId}
    </delete>

    <!-- 根据文章ID列表批量查询标签关联 -->
    <select id="findRelationsByArticleIds" resultType="com.novablog.dto.request.ArticleTagDTO">
        SELECT at.article_id as articleId, t.id as tagId, t.name as tagName
        FROM article_tag at
        INNER JOIN tag t ON at.tag_id = t.id
        WHERE at.article_id IN
        <foreach collection="articleIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY at.article_id, t.id
    </select>

</mapper>
