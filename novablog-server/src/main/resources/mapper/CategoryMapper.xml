<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.novablog.mapper.CategoryMapper">

    <resultMap id="categoryResultMap" type="com.novablog.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
    </resultMap>

    <!-- 查询所有分类 -->
    <select id="findAll" resultMap="categoryResultMap">
        SELECT * FROM category ORDER BY id
    </select>

    <!-- 根据ID查询分类 -->
    <select id="findById" resultMap="categoryResultMap">
        SELECT * FROM category WHERE id = #{id} LIMIT 1
    </select>

    <!-- 根据名称查询分类 -->
    <select id="findByName" resultMap="categoryResultMap">
        SELECT * FROM category WHERE name = #{name} LIMIT 1
    </select>

    <!-- 更新分类 -->
    <update id="update">
        UPDATE category SET name = #{name}, description = #{description} WHERE id = #{id}
    </update>

    <!-- 查询引用该分类的文章数量 -->
    <select id="countArticlesByCategoryId" resultType="java.lang.Long">
        SELECT COUNT(*) FROM article WHERE category_id = #{categoryId}
    </select>

</mapper>
